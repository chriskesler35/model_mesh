# ==============================================================================
# DevForgeAI — Root Environment Configuration
# Copy this file to .env and fill in your values.
# ==============================================================================

# Provider API Keys (at least ONE required for cloud models)
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here
GEMINI_API_KEY=your_google_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Local AI (Ollama — free, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Application
MODELMESH_API_KEY=modelmesh_local_dev_key

# Telegram Bot (optional — for remote chat access)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_IDS=your_chat_id
