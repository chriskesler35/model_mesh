# ==============================================================================
# DevForgeAI — Environment Configuration
# Copy this file to .env and fill in your values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (SQLite auto-configured; override to use PostgreSQL)
# ------------------------------------------------------------------------------
# Default: sqlite+aiosqlite:///data/devforgeai.db  ← leave blank to use SQLite
DATABASE_URL=

# ------------------------------------------------------------------------------
# AI Provider API Keys  (at least ONE is required)
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# Local AI (Ollama — free, no key needed)
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------------------
# Image Generation (optional — falls back to Gemini if ComfyUI unavailable)
# ------------------------------------------------------------------------------
COMFYUI_URL=http://localhost:8188

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_ENV=development
MODELMESH_API_KEY=modelmesh_local_dev_key
MODEL_ROUTING_AUTO_ENABLED=false
OAUTH_TOKEN_ENCRYPTION_KEY=
# Optional: persisted policy lives in DB app_settings key `model_routing_policy_json`

# ------------------------------------------------------------------------------
# GitHub OAuth (optional — "Sign in with GitHub")
# Register an app at https://github.com/settings/developers
# ------------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URL=http://localhost:3001/auth/github/callback

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3001/auth/google/callback

# ------------------------------------------------------------------------------
# Telegram Bot (optional)
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
