{
  "name": "SDXL Img2Img (Variation)",
  "description": "Image-to-image variation using SDXL. Takes a source image + optional prompt, applies partial denoising to produce a variation.",
  "category": "img2img",
  "default_checkpoint": "ponyDiffusionV6XL.safetensors",
  "compatible_checkpoints": ["ponyDiffusionV6XL.safetensors"],
  "default_size": "1024x1024",
  "sizes": ["1024x1024", "1024x768", "768x1024"],
  "workflow": {
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "cfg": 7.0,
        "denoise": 0.65,
        "latent_image": ["11", 0],
        "model": ["4", 0],
        "negative": ["7", 0],
        "positive": ["6", 0],
        "sampler_name": "dpmpp_2m_sde",
        "scheduler": "karras",
        "steps": 25,
        "seed": 0
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "{{checkpoint}}"
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "clip": ["4", 1],
        "text": "{{prompt}}"
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "clip": ["4", 1],
        "text": "{{negative_prompt}}"
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "devforgeai_var",
        "images": ["8", 0]
      }
    },
    "10": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "{{init_image}}"
      }
    },
    "11": {
      "class_type": "VAEEncode",
      "inputs": {
        "pixels": ["10", 0],
        "vae": ["4", 2]
      }
    }
  }
}
